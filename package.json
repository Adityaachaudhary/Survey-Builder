{
	"name": "survey-builder",
	"private": true,
	"scripts": {
		"dev": "concurrently --prefix-colors \"blue,green\" --names \"[api],[web]\" \"pnpm --filter survey-builder-api dev\" \"pnpm --filter survey-builder-web dev\"",
		"build": "pnpm --filter survey-builder-web build",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"typecheck": "pnpm --filter survey-builder-api typecheck && pnpm --filter survey-builder-web typecheck"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"concurrently": "^9.1.0"
	}
}
